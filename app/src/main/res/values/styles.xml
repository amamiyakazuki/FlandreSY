<resources>
    <style name="Theme.ZhuliHotwater" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowBackground">@color/zhuli_background</item>
        <item name="android:statusBarColor">@color/zhuli_background</item>
        <item name="android:navigationBarColor">@color/zhuli_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="colorPrimary">@color/zhuli_primary</item>
        <item name="colorOnPrimary">@color/zhuli_on_primary</item>
        <item name="colorPrimaryContainer">@color/zhuli_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/zhuli_on_primary_container</item>
        <item name="colorSecondary">@color/zhuli_secondary</item>
        <item name="colorOnSecondary">@color/zhuli_on_secondary</item>
        <item name="colorSecondaryContainer">@color/zhuli_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/zhuli_on_secondary_container</item>
        <item name="colorTertiary">@color/zhuli_tertiary</item>
        <item name="colorOnTertiary">@color/zhuli_on_tertiary</item>
        <item name="colorSurface">@color/zhuli_surface</item>
        <item name="colorOnSurface">@color/zhuli_on_surface</item>
        <item name="colorSurfaceVariant">@color/zhuli_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/zhuli_on_surface_variant</item>
        <item name="colorOutline">@color/zhuli_outline</item>
        <item name="colorError">@color/zhuli_error</item>
        <item name="materialButtonStyle">@style/Widget.ZhuliHotwater.Button</item>
    </style>

    <style name="Widget.ZhuliHotwater.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
