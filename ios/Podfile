# Flutter iOS Podfile. Adds AlipaySDK-iOS for real Ujing payment (RealPaymentLauncher via
# MethodChannel 'ujing/alipay'). NOTE (Codex 无法在 Linux 验证)：pod install + iOS 构建 + 真机/真钱
# 由用户在 macOS 完成。若 AlipaySDK-iOS 与 use_frameworks! 冲突，改用 :linkage => :static（见下）。
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # 支付宝 SDK（真机真实支付；RealPaymentLauncher 经 ujing/alipay channel 调用）。
  # 注：per-pod :linkage 参数 CocoaPods 1.16 不支持（会崩 pod install）。
  # 若 use_frameworks! 下静态链接报错，改用官方写法：use_frameworks! :linkage => :static。
  pod 'AlipaySDK-iOS'

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    # Xcode 26 要求最低部署目标 12.0，修复旧 pod 的 9.0/10.0 目标
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'

      # M-REAL 权限检测：permission_handler 用编译宏门控编译进哪些权限。
      # 仅开启本 App 实际用到的相机/蓝牙/定位（对齐 Info.plist 用途串 + AndroidManifest）。
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_CAMERA=1',
        'PERMISSION_BLUETOOTH=1',
        'PERMISSION_LOCATION=1',
      ]
    end
  end

  # AlipaySDK-iOS 是 vendored xcframework，
  # Xcode 26 不会在 Swift 编译前自动解包 xcframework，
  # 需直接添加内层 .framework 路径到 FRAMEWORK_SEARCH_PATHS。
  user_project = installer.aggregate_targets.first.user_project
  user_project.targets.each do |target|
    next unless target.name == 'Runner' || target.name == 'RunnerTests'
    target.build_configurations.each do |config|
      alipay_inner = '${PODS_ROOT}/AlipaySDK-iOS/AlipaySDK.xcframework/ios-arm64'
      if config.name.downcase.include?('debug')
        alipay_inner = '${PODS_ROOT}/AlipaySDK-iOS/AlipaySDK.xcframework/ios-arm64_x86_64-simulator'
      end
      current = config.build_settings['FRAMEWORK_SEARCH_PATHS'] || ['$(inherited)']
      current = [current] unless current.is_a?(Array)
      unless current.any? { |p| p.include?('AlipaySDK.xcframework') }
        config.build_settings['FRAMEWORK_SEARCH_PATHS'] = current + [alipay_inner]
      end
    end
  end
  user_project.save
end
